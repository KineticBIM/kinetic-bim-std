<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Auto Dimension"
    Width="1500" Height="900"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize">

    <!-- ====================================================================
         Per-column gating styles. Linear MEP categories have different
         strategy applicability and size sets, but in v1 the four MEP
         categories all support length + orientation, so most cells are
         always editable. Current-view-only is hard-locked on for v1.
         ==================================================================== -->
    <Window.Resources>

        <Style x:Key="GatedCell_Horizontal" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsHorizontal}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Background" Value="#F4F4F4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GatedCell_Vertical" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsVertical}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Background" Value="#F4F4F4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Current View Only is hard-locked to true in v1 - render
             read-only with a soft grey so users see it's there but
             not editable. The profile validation rejects unchecked. -->
        <Style x:Key="LockedCell" TargetType="DataGridCell">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Background" Value="#F8F8F8"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- =============================================================
             ROW 0: Discipline + multi-select subcategory list.
             ============================================================= -->
        <GroupBox Grid.Row="0" Header="Discipline and subcategories"
                  Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <Label Content="Discipline"/>
                    <ComboBox x:Name="discipline_combo" Margin="0,3"
                              SelectionChanged="discipline_changed"/>
                    <TextBlock Margin="0,12,0,0" FontStyle="Italic"
                               Foreground="#666" TextWrapping="Wrap"
                               Text="v1 supports linear MEP only (Cable Trays, Conduits, Ducts, Pipes). Other subcategories are filtered out of the list."/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Label Content="Subcategories"/>
                    <ListBox x:Name="subcategory_list"
                             SelectionMode="Multiple"
                             Height="120"
                             SelectionChanged="subcategories_changed"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- =============================================================
             ROW 1: Per-profile configuration grid.
             ============================================================= -->
        <GroupBox Grid.Row="1" Header="Dimensioning profiles (one row per ticked subcategory)"
                  Padding="6" Margin="0,0,0,8">
            <DataGrid x:Name="profile_grid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="28"
                      AlternatingRowBackground="#FAFAFA"
                      SelectionMode="Single"
                      SelectionUnit="Cell"
                      CellEditEnding="grid_cell_edited">
                <DataGrid.Columns>

                    <DataGridCheckBoxColumn Header="On"
                                            Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                            Width="38"/>

                    <DataGridTextColumn Header="Discipline"
                                        Binding="{Binding DisciplineLabel}"
                                        IsReadOnly="True"
                                        Width="100"/>

                    <DataGridTextColumn Header="Subcategory"
                                        Binding="{Binding SubcategoryLabel}"
                                        IsReadOnly="True"
                                        Width="140"/>

                    <DataGridTextColumn Header="Min Len mm"
                                        Binding="{Binding MinLengthText, UpdateSourceTrigger=LostFocus}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Max Len mm"
                                        Binding="{Binding MaxLengthText, UpdateSourceTrigger=LostFocus}"
                                        Width="80"/>

                    <DataGridCheckBoxColumn Header="Horiz"
                                            Binding="{Binding HorizontalOnly, UpdateSourceTrigger=PropertyChanged}"
                                            Width="44"
                                            CellStyle="{StaticResource GatedCell_Horizontal}"/>
                    <DataGridCheckBoxColumn Header="Vert"
                                            Binding="{Binding VerticalOnly, UpdateSourceTrigger=PropertyChanged}"
                                            Width="44"
                                            CellStyle="{StaticResource GatedCell_Vertical}"/>
                    <DataGridTextColumn Header="Tol &#176;"
                                        Binding="{Binding OrientationTolText, UpdateSourceTrigger=LostFocus}"
                                        Width="50"/>

                    <!-- Current View Only - hard-locked to true in v1 -->
                    <DataGridCheckBoxColumn Header="Curr View"
                                            Binding="{Binding CurrentViewOnly, UpdateSourceTrigger=PropertyChanged}"
                                            Width="60"
                                            CellStyle="{StaticResource LockedCell}"/>

                    <DataGridCheckBoxColumn Header="Skip Dim'd"
                                            Binding="{Binding SkipAlreadyDimensioned, UpdateSourceTrigger=PropertyChanged}"
                                            Width="60"/>

                    <!-- Measurement reference - per-row, category-specific -->
                    <DataGridTemplateColumn Header="Measurement reference"
                                            Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding MeasurementOptions}"
                                          DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedMeasurementOption,
                                                                 UpdateSourceTrigger=PropertyChanged,
                                                                 Mode=TwoWay}"
                                          BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Reference target - per-row -->
                    <DataGridTemplateColumn Header="Reference target"
                                            Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding TargetOptions}"
                                          DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedTargetOption,
                                                                 UpdateSourceTrigger=PropertyChanged,
                                                                 Mode=TwoWay}"
                                          BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Dimension style - per-row -->
                    <DataGridTemplateColumn Header="Dimension style"
                                            Width="*"
                                            MinWidth="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DimensionStyleOptions}"
                                          DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedDimensionStyleOption,
                                                                 UpdateSourceTrigger=PropertyChanged,
                                                                 Mode=TwoWay}"
                                          BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Offset mm"
                                        Binding="{Binding OffsetDistanceText, UpdateSourceTrigger=LostFocus}"
                                        Width="80"/>

                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- =============================================================
             ROW 2: Results console.
             ============================================================= -->
        <GroupBox Grid.Row="2" Header="Results" Margin="0,0,0,8" Height="240">
            <TextBox x:Name="results_box"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"/>
        </GroupBox>

        <!-- =============================================================
             ROW 3: Action buttons.
             ============================================================= -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Scan Model" Width="130" Height="30" Margin="4,0"
                    Click="scan_clicked"/>
            <Button Content="Place Dimensions" Width="150" Height="30" Margin="4,0"
                    Click="place_clicked"/>
            <Button Content="Save Report" Width="130" Height="30" Margin="4,0"
                    Click="report_clicked"/>
            <Button Content="Save Excel" Width="130" Height="30" Margin="4,0"
                    Click="csv_clicked"/>
            <Button Content="Close" Width="80" Height="30" Margin="12,0,0,0"
                    Click="close_clicked"/>
        </StackPanel>
    </Grid>
</Window>
